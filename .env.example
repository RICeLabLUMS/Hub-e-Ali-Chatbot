# Qdrant vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenRouter (Claude / GPT-4o / etc.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# API auth header (X-API-Key)
API_KEY=change-me-in-production

# Local working dirs (Windows-safe relative paths)
UPLOAD_DIR=./tmp/rag_uploads

# Embedding device: auto | cuda | cpu
EMBEDDING_DEVICE=auto

# Retrieval tuning
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
