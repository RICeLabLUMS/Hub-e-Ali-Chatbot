# Qdrant vector DB
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# OpenRouter (Claude / GPT-4o / etc.)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# API auth header (X-API-Key)
API_KEY=change-me-in-production

# Local working dirs (Windows-safe relative paths)
UPLOAD_DIR=./tmp/rag_uploads

# Embedding device: auto | cuda | cpu
EMBEDDING_DEVICE=auto

# Retrieval tuning
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
# Reranker truncation cap. bge-reranker-v2-m3 supports 8192; 1024 fits any
# typical chunk (~500 tokens) + query comfortably. Bump if you increased
# chunk_size or routinely see very long chunks getting truncated at rerank time.
RERANKER_MAX_LENGTH=1024

# OCR (Surya, applied only to scanned PDF pages with no text layer).
# Render multiplier passed to PyMuPDF before OCR. 3 is a strong default for
# printed Arabic/Urdu; raise to 4 if you have very low-DPI source scans.
OCR_RENDER_SCALE=3.0
# Minimum line confidence to keep. Lower = include borderline-legible text
# (more recall, more noise); higher = cleaner chunks (less recall).
OCR_CONFIDENCE_THRESHOLD=0.6
# Use Surya's LayoutPredictor for model-based reading order + semantic region
# labels (Title / Text / List / Footnote / etc). Better multi-column handling
# and structural markup; ~2x slower per scanned page. Falls back to bbox
# heuristics if Surya layout model can't be loaded.
OCR_USE_LAYOUT=true

# WordPress sync (optional — only needed if syncing content from a WP site)
# Generate the app password in WP admin: Users -> Profile -> Application Passwords
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
# Comma-separated CPT slugs (REST route segment), e.g. "lectures,fatwas". Leave blank for none.
WORDPRESS_CPT_ROUTES=
WORDPRESS_SYNC_INTERVAL_MINUTES=60
WORDPRESS_STATE_FILE=./tmp/wordpress_sync_state.json
# Set true to enable the in-process APScheduler hook in app/main.py lifespan.
# Leave false if you only run the CLI script via Windows Task Scheduler / cron.
WORDPRESS_SYNC_ENABLED=false
# Override only if your WP site's WAF requires a specific User-Agent.
# Default mimics Chrome to get past WAFs that block non-browser UAs.
#WORDPRESS_USER_AGENT=
# Set false if your WP site uses a self-signed cert (dev only - production should always verify).
WORDPRESS_VERIFY_SSL=true
# Discover PDFs linked from post/page bodies (static files outside /wp-content/uploads/).
# When true, each unique PDF URL referenced by any post is downloaded and indexed once.
WORDPRESS_INGEST_LINKED_PDFS=true
# Comma-separated extra hosts allowed for linked-PDF downloads (WP site's own host is always allowed).
#WORDPRESS_LINKED_PDF_HOSTS=cdn.example.com,docs.example.com
